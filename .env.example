# ==============================================================================
# HCHO ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' and fill in local values. DO NOT COMMIT '.env' to git!
# ==============================================================================

# 1. APPLICATION ENVIRONMENT
APP_ENV=development
SECRET_KEY=generate_a_secure_random_string_here_for_jwt_signing
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 2. RELATIONAL DATABASE (POSTGRESQL + POSTGIS)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass
DB_NAME=hcho_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass@localhost:5432/hcho_db

# 3. TASK BROKER & CACHE (REDIS)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass
CELERY_BROKER_URL=redis://:redis_secure_pass@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secure_pass@localhost:6379/0

# 4. VECTOR DATABASE (QDRANT)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# 5. EARTH OBSERVATION & SATELLITE APIS
# Sentinel Hub Credentials
SH_CLIENT_ID=your_sentinel_hub_client_id_here
SH_CLIENT_SECRET=your_sentinel_hub_client_secret_here

# Google Earth Engine
EE_PROJECT=your_gee_gcp_project_id_here
EE_SERVICE_ACCOUNT=your_service_account_email_here
# Path to service account json key file
EE_JSON_KEY_FILE=config/gee_key.json

# Planetary Computer
PLANETARY_COMPUTER_API_KEY=your_planetary_computer_api_key_here

# 6. OBSERVABILITY & MONITORING
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_secure_pass
SENTRY_DSN=
